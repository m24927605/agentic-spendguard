# Onboarding budget bootstrap — Phase 5 S20.
#
# These env vars feed `make onboard-bootstrap` which calls
# Control Plane to provision tenant + budget + window. Replace
# every __PLACEHOLDER__ before running.
#
# DO NOT commit a filled-in copy of this file with secrets. The
# control-plane admin token belongs in your secrets manager, not
# git.

# Control Plane endpoint (operator's spendguard deployment).
CONTROL_PLANE_URL=https://control-plane.spendguard.example.com
# OIDC bearer for an admin role principal — see S17 runbook for
# how to obtain. Demo profile: paste your demo admin token here.
ADMIN_BEARER_TOKEN=__REPLACE_WITH_OIDC_BEARER_OR_DEMO_ADMIN_TOKEN__

# Tenant identity. Generate with `uuidgen`.
TENANT_ID=__TENANT_UUID_V4__
TENANT_NAME=__YOUR_WORKFLOW_NAME__

# Initial deposit in atomic units of `BUDGET_UNIT_KIND`.
#   - usd_micros: 1 USD = 1,000,000 atomic
#   - token:      1 token = 1 atomic
OPENING_DEPOSIT_ATOMIC=10000000000   # 10,000 USD = 10_000_000_000 micro-USD
BUDGET_UNIT_KIND=usd_micros

# Region label — operators with multi-region deployments use this
# to scope the tenant. Single-region deployments leave at default.
REGION=us-west-2
