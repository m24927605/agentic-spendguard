FROM rust:1.88-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY services/control_plane ./services/control_plane
WORKDIR /build/services/control_plane
RUN cargo build --release --bin spendguard-control-plane

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder \
     /build/services/control_plane/target/release/spendguard-control-plane \
     /usr/local/bin/spendguard-control-plane

ENTRYPOINT ["/usr/local/bin/spendguard-control-plane"]
