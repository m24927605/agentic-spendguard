# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
# Phase 5 GA hardening S17: shared auth crate.
COPY services/auth ./services/auth
COPY services/control_plane ./services/control_plane
WORKDIR /build/services/control_plane
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-control-plane,target=/build/services/control_plane/target,sharing=locked \
    cargo build --release --bin spendguard-control-plane \
    && cp target/release/spendguard-control-plane /spendguard-control-plane

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-control-plane /usr/local/bin/spendguard-control-plane

ENTRYPOINT ["/usr/local/bin/spendguard-control-plane"]
