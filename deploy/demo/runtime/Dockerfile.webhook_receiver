FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev protobuf-compiler libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto ./proto
# Symlink protobuf well-known types into proto_root so protoc resolves
# google.protobuf.* imports (matches Dockerfile.canonical_ingest pattern).
RUN ln -sf /usr/include/google ./proto/google
# Phase 5 GA hardening S6: signing path-dep crate.
COPY services/signing ./services/signing
COPY services/webhook_receiver ./services/webhook_receiver
WORKDIR /build/services/webhook_receiver
RUN cargo build --release --bin spendguard-webhook-receiver

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder \
     /build/services/webhook_receiver/target/release/spendguard-webhook-receiver \
     /usr/local/bin/spendguard-webhook-receiver

ENTRYPOINT ["/usr/local/bin/spendguard-webhook-receiver"]
