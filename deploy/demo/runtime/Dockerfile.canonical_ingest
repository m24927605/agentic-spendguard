# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev protobuf-compiler libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto ./proto
# Symlink protobuf well-known types into proto_root so protoc resolves
# google.protobuf.* imports (see Dockerfile.ledger for the rationale).
RUN ln -sf /usr/include/google ./proto/google
# Phase 5 GA hardening S8: signing path-dep crate (Verifier trait).
COPY services/signing ./services/signing
COPY services/canonical_ingest ./services/canonical_ingest
WORKDIR /build/services/canonical_ingest
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-canonical-ingest,target=/build/services/canonical_ingest/target,sharing=locked \
    cargo build --release --bin spendguard-canonical-ingest \
    && cp target/release/spendguard-canonical-ingest /spendguard-canonical-ingest

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-canonical-ingest /usr/local/bin/spendguard-canonical-ingest

ENTRYPOINT ["/usr/local/bin/spendguard-canonical-ingest"]
