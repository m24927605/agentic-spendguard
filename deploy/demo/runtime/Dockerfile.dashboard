FROM rust:1.88-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
# Phase 5 GA hardening S17: shared auth crate.
COPY services/auth ./services/auth
COPY services/dashboard ./services/dashboard
WORKDIR /build/services/dashboard
RUN cargo build --release --bin spendguard-dashboard

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder \
     /build/services/dashboard/target/release/spendguard-dashboard \
     /usr/local/bin/spendguard-dashboard

ENTRYPOINT ["/usr/local/bin/spendguard-dashboard"]
