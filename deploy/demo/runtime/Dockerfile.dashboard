# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
# Phase 5 GA hardening S17: shared auth crate.
COPY services/auth ./services/auth
COPY services/dashboard ./services/dashboard
WORKDIR /build/services/dashboard
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-dashboard,target=/build/services/dashboard/target,sharing=locked \
    cargo build --release --bin spendguard-dashboard \
    && cp target/release/spendguard-dashboard /spendguard-dashboard

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-dashboard /usr/local/bin/spendguard-dashboard

ENTRYPOINT ["/usr/local/bin/spendguard-dashboard"]
