# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
# Slice 2: shared ids crate consumed via path dep
COPY services/ids ./services/ids
COPY services/egress_proxy ./services/egress_proxy
WORKDIR /build/services/egress_proxy
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-egress-proxy,target=/build/services/egress_proxy/target,sharing=locked \
    cargo build --release --bin spendguard-egress-proxy \
    && cp target/release/spendguard-egress-proxy /spendguard-egress-proxy

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-egress-proxy /usr/local/bin/spendguard-egress-proxy

ENTRYPOINT ["/usr/local/bin/spendguard-egress-proxy"]
