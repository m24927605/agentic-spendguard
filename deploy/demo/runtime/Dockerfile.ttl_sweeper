# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev protobuf-compiler libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto ./proto
RUN ln -sf /usr/include/google ./proto/google
# Phase 5 S1: shared lease primitive consumed via path dep.
COPY services/leases ./services/leases
# Phase 5 S6: shared signing primitive consumed via path dep.
COPY services/signing ./services/signing
COPY services/ttl_sweeper ./services/ttl_sweeper
WORKDIR /build/services/ttl_sweeper
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-ttl-sweeper,target=/build/services/ttl_sweeper/target,sharing=locked \
    cargo build --release --bin spendguard-ttl-sweeper \
    && cp target/release/spendguard-ttl-sweeper /spendguard-ttl-sweeper

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-ttl-sweeper /usr/local/bin/spendguard-ttl-sweeper

ENTRYPOINT ["/usr/local/bin/spendguard-ttl-sweeper"]
