# syntax=docker/dockerfile:1.7
FROM rust:1.91-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev protobuf-compiler libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto ./proto
# Symlink protobuf well-known types into proto_root so protoc resolves
# google.protobuf.* imports (see Dockerfile.ledger for the rationale).
RUN ln -sf /usr/include/google ./proto/google
# Phase 5 GA hardening S6: signing path-dep crate.
COPY services/signing ./services/signing
# Phase 5 GA hardening S22: fail-policy path-dep crate.
COPY services/policy ./services/policy
COPY services/sidecar ./services/sidecar
WORKDIR /build/services/sidecar
RUN --mount=type=cache,id=cargo-registry,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,id=cargo-git,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,id=cargo-target-sidecar,target=/build/services/sidecar/target,sharing=locked \
    cargo build --release --bin spendguard-sidecar \
    && cp target/release/spendguard-sidecar /spendguard-sidecar

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /spendguard-sidecar /usr/local/bin/spendguard-sidecar

COPY deploy/demo/runtime/sidecar-entrypoint.sh /usr/local/bin/sidecar-entrypoint.sh
RUN chmod +x /usr/local/bin/sidecar-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sidecar-entrypoint.sh"]
