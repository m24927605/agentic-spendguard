FROM rust:1.88-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev protobuf-compiler libprotobuf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto ./proto
# Symlink protobuf well-known types into proto_root so protoc resolves
# google.protobuf.* imports (see Dockerfile.ledger for the rationale).
RUN ln -sf /usr/include/google ./proto/google
COPY services/sidecar ./services/sidecar
WORKDIR /build/services/sidecar
RUN cargo build --release --bin spendguard-sidecar

# ---------------------------------------------------------------------------

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder \
     /build/services/sidecar/target/release/spendguard-sidecar \
     /usr/local/bin/spendguard-sidecar

COPY deploy/demo/runtime/sidecar-entrypoint.sh /usr/local/bin/sidecar-entrypoint.sh
RUN chmod +x /usr/local/bin/sidecar-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/sidecar-entrypoint.sh"]
