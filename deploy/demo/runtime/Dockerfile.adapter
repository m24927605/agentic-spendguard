# Demo container: builds the spendguard-pydantic-ai adapter from source,
# generates Python proto stubs from the workspace `proto/` tree, and
# drops in the demo runner script. The runner connects to the sidecar
# via UDS and exercises the gated Pydantic-AI Agent flow with a Mock LLM.

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential make ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install adapter dev deps (grpcio-tools is needed for `make proto`).
RUN pip install --no-cache-dir \
    "grpcio>=1.62" \
    "grpcio-tools>=1.62" \
    "protobuf>=4.25,<6" \
    "pydantic>=2.6" \
    "pydantic-ai>=0.0.20,<0.1.0"

WORKDIR /build
COPY proto ./proto
COPY adapters/pydantic-ai ./adapters/pydantic-ai

# Generate the proto stubs (writes under
# adapters/pydantic-ai/src/spendguard_pydantic_ai/_proto/).
WORKDIR /build/adapters/pydantic-ai
RUN make proto

# Install the adapter into site-packages so the demo runner can import.
RUN pip install --no-cache-dir .

# Copy the demo runner + entrypoint that sources bundles runtime.env.
COPY deploy/demo/demo/run_demo.py /usr/local/bin/run_demo.py
COPY deploy/demo/runtime/demo-entrypoint.sh /usr/local/bin/demo-entrypoint.sh
RUN chmod +x /usr/local/bin/run_demo.py /usr/local/bin/demo-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/demo-entrypoint.sh"]
