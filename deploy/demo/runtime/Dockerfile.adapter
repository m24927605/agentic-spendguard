# Demo container: builds the spendguard-sdk Python package from source,
# generates Python proto stubs from the workspace `proto/` tree, and
# drops in the demo runner script. The runner connects to the sidecar
# via UDS and exercises the gated Pydantic-AI Agent flow.

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential make ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install adapter dev deps (grpcio-tools is needed for `make proto`).
# Anthropic SDK added for DEMO_MODE=agent_real_anthropic; httpx for the
# webhook simulator path.
RUN pip install --no-cache-dir \
    "grpcio>=1.62" \
    "grpcio-tools>=1.62" \
    "protobuf>=4.25,<6" \
    "pydantic>=2.6" \
    "pydantic-ai>=0.0.20,<0.1.0" \
    "httpx>=0.27"

WORKDIR /build
COPY proto ./proto
COPY sdk/python ./sdk/python

# Generate the proto stubs (writes under sdk/python/src/spendguard/_proto/).
WORKDIR /build/sdk/python
RUN make proto

# Install the SDK with the [pydantic-ai] extra so the demo runner can
# import spendguard.integrations.pydantic_ai. (LangChain / OpenAI Agents
# extras are added when those demo modes ship.)
RUN pip install --no-cache-dir '.[pydantic-ai]'

# Copy the demo runner + entrypoint that sources bundles runtime.env.
COPY deploy/demo/demo/run_demo.py /usr/local/bin/run_demo.py
COPY deploy/demo/runtime/demo-entrypoint.sh /usr/local/bin/demo-entrypoint.sh
RUN chmod +x /usr/local/bin/run_demo.py /usr/local/bin/demo-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/demo-entrypoint.sh"]
