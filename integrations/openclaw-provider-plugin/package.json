{
  "name": "@spendguard/openclaw-provider-plugin",
  "version": "0.1.0",
  "description": "SpendGuard OpenClaw provider plugin adapter skeleton for pinned OpenClaw provider registration APIs.",
  "license": "Apache-2.0",
  "author": "Michael Chen <m24927605@gmail.com>",
  "homepage": "https://github.com/m24927605/agentic-spendguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/m24927605/agentic-spendguard.git",
    "directory": "integrations/openclaw-provider-plugin"
  },
  "bugs": "https://github.com/m24927605/agentic-spendguard/issues",
  "keywords": [
    "llm",
    "agent",
    "spend",
    "budget",
    "spendguard",
    "openclaw",
    "provider-plugin",
    "guardrails"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE_NOTICES.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "size": "sh scripts/size-budget.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit"
  },
  "peerDependencies": {
    "@spendguard/sdk": "^0.5.0",
    "openclaw": "2026.6.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openclaw": "2026.6.8",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
