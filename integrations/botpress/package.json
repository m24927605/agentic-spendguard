{
  "name": "@spendguard/botpress-integration",
  "version": "0.1.0",
  "description": "SpendGuard Botpress LLM-provider integration — fail-closed, pre-dispatch budget reservation for Botpress LLM spend. Implements the Botpress `generateContent` action: reserves spend against the SpendGuard sidecar HTTP companion before forwarding to the upstream provider (OpenAI / Anthropic / Bedrock), then commits real usage after the call. Throws Botpress RuntimeError on DENY / DEGRADE / config errors.",
  "license": "Apache-2.0",
  "author": "Michael Chen <m24927605@gmail.com>",
  "homepage": "https://github.com/m24927605/agentic-spendguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/m24927605/agentic-spendguard.git",
    "directory": "integrations/botpress"
  },
  "bugs": "https://github.com/m24927605/agentic-spendguard/issues",
  "keywords": [
    "llm",
    "agent",
    "spend",
    "budget",
    "spendguard",
    "botpress",
    "integration-sdk",
    "generateContent",
    "llm-provider",
    "guardrails"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "botpress.integration.yaml",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bp:build": "bp build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "bp:push": "bp deploy"
  },
  "peerDependencies": {
    "@botpress/sdk": ">=6.11.0 <6.12.0",
    "@spendguard/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@botpress/cli": "6.8.6",
    "@botpress/sdk": "6.11.1",
    "@spendguard/sdk": "workspace:*",
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "bpDependencies": {
    "llm": "interface:llm@10.0.0"
  }
}