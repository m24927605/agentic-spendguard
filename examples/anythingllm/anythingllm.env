# SpendGuard + AnythingLLM — drop-in env file (Pattern 2, base-URL redirect).
#
# Pass this file to `docker run --env-file ./anythingllm.env` or paste
# the values into the `environment:` block of a compose file. The
# defaults assume:
#   - SpendGuard egress proxy is reachable at http://host.docker.internal:9000
#     (Docker Desktop on macOS / Windows). For Linux, swap to the host
#     loopback bridge IP or run AnythingLLM on the same Docker network
#     as the egress proxy and use http://egress-proxy:9000.
#   - You want AnythingLLM to listen on its default port 3001.
#   - Storage persists across container restarts via the
#     /app/server/storage volume mount.
#
# To populate the LLM Preference panel without clicking through the
# UI, POST `generic-openai-config.json` to AnythingLLM's
# `/api/v1/system/update-env` after first boot. See `setup.sh`.
#
# Reference: docs/site-v2/src/content/docs/docs/drop-in/anythingllm.mdx
# Spec:      docs/specs/coverage/D33_anythingllm_recipe/design.md

# --- AnythingLLM runtime ---
STORAGE_DIR=/app/server/storage
SERVER_PORT=3001

# --- Generic OpenAI provider defaults ---
# AnythingLLM reads these on boot if no LLM Preference is persisted in
# storage. After `setup.sh` runs they are also written back to the
# storage volume so manual GUI edits survive container restarts.
LLM_PROVIDER=generic-openai

# Trailing /v1 is mandatory — AnythingLLM appends /chat/completions to
# whatever path you set. Swap host.docker.internal for your egress URL.
GENERIC_OPEN_AI_BASE_PATH=http://host.docker.internal:9000/v1

# Any non-empty string. SpendGuard's egress proxy ignores the inbound
# Authorization header and substitutes the upstream credential from
# its own config. AnythingLLM rejects an empty key at panel save time.
GENERIC_OPEN_AI_API_KEY=sk-anythingllm-spendguard

# Model identifier the real upstream expects. SpendGuard does not
# rewrite this. Override per your upstream provider config.
GENERIC_OPEN_AI_MODEL_PREF=gpt-4o-mini

# AnythingLLM-side rate-limit hint. SpendGuard's contract decides the
# real reservation size; this number is informational on the
# AnythingLLM side only.
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=128000
