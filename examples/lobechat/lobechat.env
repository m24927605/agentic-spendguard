# SpendGuard + LobeChat — drop-in env file (Pattern 2, base-URL redirect).
#
# Pass this file to `docker run --env-file ./lobechat.env` or paste
# the values into the `environment:` block of a compose file. The
# defaults assume:
#   - SpendGuard egress proxy is reachable at http://host.docker.internal:9000
#     (Docker Desktop on macOS / Windows). For Linux, swap to the host
#     loopback bridge IP or run LobeChat on the same Docker network
#     as the egress proxy and use http://egress-proxy:9000.
#   - You want LobeChat to listen on its default port 3210.
#   - You will pass OPENAI_API_KEY separately on the docker run command
#     line (do NOT commit a real key to this env file).
#
# Reference: docs/site-v2/src/content/docs/docs/drop-in/lobechat.mdx
# Spec:      docs/specs/coverage/D34_lobechat_recipe/design.md

# --- LobeChat runtime ---
# Server mode is the ONLY configuration where OPENAI_PROXY_URL gates
# every chat. Client mode (browser keys) bypasses the env var; per
# lobechat.mdx Gotchas section. Do not override this to "client".
NEXT_PUBLIC_SERVICE_MODE=server

# UI gate. LobeChat refuses anonymous browser sessions when ACCESS_CODE
# is set; the server route at /api/chat/openai requires it in the
# X-LOBE-CHAT-AUTH header. Rotate per environment.
ACCESS_CODE=spendguard-lobechat-default

# --- SpendGuard proxy wiring ---
# Trailing /v1 is mandatory — LobeChat appends /chat/completions to
# whatever path you set. Swap host.docker.internal for your egress URL.
OPENAI_PROXY_URL=http://host.docker.internal:9000/v1

# Optional: pin the model list shown to LobeChat UI users. The "+" prefix
# adds a model to the default list; without it, LobeChat replaces the
# default list entirely. SpendGuard does not rewrite the model name in
# the request body; whatever value LobeChat picks here flows through to
# the upstream provider.
OPENAI_MODEL_LIST=+gpt-4o-mini
