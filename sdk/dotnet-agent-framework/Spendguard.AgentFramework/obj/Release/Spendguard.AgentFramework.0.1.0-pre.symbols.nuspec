<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Spendguard.AgentFramework</id>
    <version>0.1.0-pre</version>
    <authors>SpendGuard Authors</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/spendguardhq/agentic-spendguard</projectUrl>
    <description>SpendGuard middleware for Microsoft Agent Framework. Gates LLM calls against the SpendGuard sidecar (UDS gRPC) so every call reserves budget, audits via canonical_events, and fails closed by default.</description>
    <releaseNotes>0.1.0-pre: initial pre-release. SLICE_01-04 bundled (csproj + UDS gRPC client + middleware + xUnit tests).</releaseNotes>
    <copyright>Copyright (c) SpendGuard Authors</copyright>
    <tags>spendguard maf agent-framework budget llm observability</tags>
    <repository type="git" url="https://github.com/spendguardhq/agentic-spendguard" commit="ab227fd68b1f497e49712cbe2d3bd334a0c03e8e" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Google.Protobuf" version="[3.27.0, 4.0.0)" exclude="Build,Analyzers" />
        <dependency id="Grpc.Net.Client" version="[2.65.0, 3.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Agents.AI.Abstractions" version="[1.9.0, 2.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.AI.Abstractions" version="[10.5.1, 12.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="[8.0.0, 11.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="[8.0.0, 11.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Options" version="[8.0.0, 11.0.0)" exclude="Build,Analyzers" />
        <dependency id="System.IO.Hashing" version="[8.0.0, 11.0.0)" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>