{
  "name": "@spendguard/inngest-agent-kit",
  "version": "0.1.1",
  "description": "Inngest AgentKit adapter for SpendGuard budget guardrails — drop-in via `wrapWithSpendGuard(step.ai, client, opts)` inside an Inngest function, retry-safe by step identity.",
  "license": "Apache-2.0",
  "author": "Michael Chen <m24927605@gmail.com>",
  "homepage": "https://github.com/m24927605/agentic-spendguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/m24927605/agentic-spendguard.git",
    "directory": "sdk/typescript-inngest-agent-kit"
  },
  "bugs": "https://github.com/m24927605/agentic-spendguard/issues",
  "keywords": [
    "llm",
    "agent",
    "spend",
    "budget",
    "spendguard",
    "inngest",
    "inngest-agent-kit",
    "agent-kit",
    "durable",
    "step",
    "guardrails"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE_NOTICES.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "size": "bash scripts/size-budget.sh",
    "version-check": "bash scripts/version-check.sh",
    "prepublishOnly": "bash scripts/prepublish.sh"
  },
  "peerDependencies": {
    "@spendguard/sdk": "^0.5.0",
    "@inngest/agent-kit": ">=0.13 <1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@inngest/agent-kit": "^0.13.2",
    "@spendguard/sdk": "^0.5.0",
    "@types/node": "^20.14.0",
    "inngest": "^3.43.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^4.4.0"
  }
}
