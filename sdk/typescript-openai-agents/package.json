{
  "name": "@spendguard/openai-agents",
  "version": "0.1.1",
  "description": "OpenAI Agents SDK (TypeScript) adapter for SpendGuard budget guardrails — drop-in via `withSpendGuard(model, opts)` on any `@openai/agents` Model.",
  "license": "Apache-2.0",
  "author": "Michael Chen <m24927605@gmail.com>",
  "homepage": "https://github.com/m24927605/agentic-spendguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/m24927605/agentic-spendguard.git",
    "directory": "sdk/typescript-openai-agents"
  },
  "bugs": "https://github.com/m24927605/agentic-spendguard/issues",
  "keywords": [
    "llm",
    "agent",
    "spend",
    "budget",
    "spendguard",
    "openai",
    "openai-agents",
    "agents-sdk",
    "guardrails"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE_NOTICES.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./run-context": {
      "types": "./dist/runContext.d.ts",
      "import": "./dist/runContext.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "prepublishOnly": "bash scripts/prepublish.sh"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0"
  },
  "peerDependencies": {
    "@spendguard/sdk": "^0.5.0",
    "@openai/agents": ">=0.11 <1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@openai/agents": "^0.11.6",
    "@spendguard/sdk": "^0.5.0",
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
